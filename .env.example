# ============================================================================
# Kodi shared media-center configuration
# Copy this file to ".env" and adjust the values, then run ./scripts/setup.sh
# ============================================================================

# --- Network -----------------------------------------------------------------
# IP address of the SERVER that hosts the media files + shared library database.
SERVER_IP=192.168.1.177
# IP address of the TABLET running Kodi (informational only; used in docs).
TABLET_IP=192.168.1.163

# --- MariaDB (shared Kodi library database) ----------------------------------
DB_PORT=3306
MYSQL_ROOT_PASSWORD=change-me-root-password
# Account Kodi uses to create/own its MyVideos*/MyMusic* databases.
KODI_DB_USER=kodi
KODI_DB_PASSWORD=kodi

# --- Samba (media file shares) -----------------------------------------------
SAMBA_USER=kodi
SAMBA_PASSWORD=kodi
# Host directory that contains the Movies/ TVShows/ Music/ subfolders.
MEDIA_ROOT=./media

# --- Tablet standalone (offline) mode ----------------------------------------
# Where media lives ON the tablet itself, used in STANDALONE mode so the tablet
# plays with no network. On Android this is typically internal storage.
TABLET_LOCAL_MEDIA=/storage/emulated/0

# --- Backups (shared library database) ---------------------------------------
# How many backup files to keep (older ones are pruned).
BACKUP_KEEP=14
# Schedule for the optional automated backup container (cron syntax).
# Quote it: it contains spaces so scripts that read .env parse it correctly.
BACKUP_CRON="30 3 * * *"
